# Custom Region 输出
output "custom_region_uuid" {
  value       = guance_custom_region.example2.uuid
  description = "The UUID of the created custom region"
}

output "custom_region_ak" {
  value       = guance_custom_region.example2.ak.ak
  description = "The AK of the created custom region"
}

output "custom_region_sk" {
  value       = guance_custom_region.example2.ak.sk
  description = "The SK of the created custom region"
  sensitive   = true
}