# Custom Region 示例
resource "guance_custom_region" "example2" {
  internal = false
  isp      = "telecom"
  country  = "Afghanistan"
  city     = "Farah"
  name     = "TF Custom Region"
  keycode  = "afghanistan-farah-telecom-new-4"
}

